<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WifiSender.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="700"
        x:Class="WifiSender.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="WifiSender - File Transfer"
        Width="800" Height="750"
        MinWidth="700" MinHeight="650"
        Background="#1C1B1F"
        Icon="/Assets/appicon.ico">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#D0BCFF"/>
            <Setter Property="Foreground" Value="#381E72"/>
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E8DEF8"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#D0BCFF"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.38"/>
        </Style>

        <Style Selector="Button.Tonal">
            <Setter Property="Background" Value="#4A4458"/>
            <Setter Property="Foreground" Value="#E8DEF8"/>
        </Style>
        <Style Selector="Button.Tonal:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#5F5A6E"/>
        </Style>

        <Style Selector="Button.FilledSuccess">
            <Setter Property="Background" Value="#4ADE80"/>
            <Setter Property="Foreground" Value="#052E16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>
        <Style Selector="Button.FilledSuccess:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#86EFAC"/>
        </Style>
        <Style Selector="Button.FilledSuccess:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#22C55E"/>
        </Style>

        <Style Selector="Button.FilledSecondary">
            <Setter Property="Background" Value="#CCC2DC"/>
            <Setter Property="Foreground" Value="#332D41"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>
        <Style Selector="Button.FilledSecondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D8BEF8"/>
        </Style>

        <Style Selector="Button.FilledTertiary">
            <Setter Property="Background" Value="#EFB8C8"/>
            <Setter Property="Foreground" Value="#492532"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="32,16"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>
        <Style Selector="Button.FilledTertiary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F4C7D5"/>
        </Style>

        <Style Selector="Button.IconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>
        <Style Selector="Button.IconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4458"/>
        </Style>

        <Style Selector="Button.Outlined">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D0BCFF"/>
            <Setter Property="BorderBrush" Value="#938F99"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style Selector="Button.Outlined:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A4458"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2B2930"/>
            <Setter Property="Foreground" Value="#E6E1E5"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="Background" Value="#2B2930"/>
            <Setter Property="BorderBrush" Value="#D0BCFF"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="#36343B"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#4A4458"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="Background" Value="#36343B"/>
        </Style>

        <Style Selector="ProgressBar">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Background" Value="#4A4458"/>
            <Setter Property="Foreground" Value="#D0BCFF"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="24,16"/>
            <Setter Property="CornerRadius" Value="16,16,0,0"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#4A4458"/>
        </Style>

        <Style Selector="Border.Card">
            <Setter Property="Background" Value="#2B2930"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style Selector="Border.Elevated">
            <Setter Property="Background" Value="#36343B"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Material 3 Dark Header -->
        <Border DockPanel.Dock="Top" Background="#1C1B1F" Padding="24,20">
            <Border Background="#2B2930" CornerRadius="28" Padding="4">
                <Grid ColumnDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Background="#6750A4" CornerRadius="20" Padding="12">
                            <TextBlock Text="📤" FontSize="24"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="WifiSender" FontSize="22" FontWeight="SemiBold" Foreground="#E6E1E5"/>
                            <TextBlock Text="Fast &amp; Secure File Transfer" FontSize="13" Foreground="#CAC4D0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Tab Control -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="24,16,24,24">
            
            <!-- SEND TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📤" FontSize="18"/>
                        <TextBlock Text="Send" VerticalAlignment="Center" Foreground="#E6E1E5"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer Padding="0,24,0,0">
                    <StackPanel Spacing="16">
                        
                        <!-- Connection Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="#4A4458" CornerRadius="12" Padding="10">
                                        <TextBlock Text="🌐" FontSize="20"/>
                                    </Border>
                                    <TextBlock Text="Connection" FontSize="20" FontWeight="SemiBold" Foreground="#E6E1E5" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Your IP" VerticalAlignment="Center" 
                                               Foreground="#CAC4D0" FontWeight="Medium" Margin="0,0,24,0"/>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#4A4458" CornerRadius="8" Padding="16,12" HorizontalAlignment="Left" MinWidth="180">
                                        <TextBlock Text="{Binding LocalIp}" FontWeight="SemiBold" Foreground="#B8F0C2" FontSize="15"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" VerticalAlignment="Center" 
                                               Foreground="#CAC4D0" FontWeight="Medium" Margin="0,16,24,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Width="100" HorizontalAlignment="Left" Margin="0,16,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Send to" VerticalAlignment="Center" 
                                               Foreground="#CAC4D0" FontWeight="Medium" Margin="0,16,24,0"/>
                                    <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
                                        <TextBox Text="{Binding RecipientIp}" Watermark="IP address..."/>
                                        <Button Grid.Column="1" Content="Test" Command="{Binding TestConnectionCommand}" 
                                                Classes="Outlined" Padding="16,10" Margin="12,0,0,0"/>
                                    </Grid>
                                </Grid>
                                <TextBlock Text="{Binding ConnectionTestResult}" Foreground="#CAC4D0" FontSize="12" Margin="100,4,0,0"/>

                                <Border Classes="Elevated">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="Find Nearby Devices" FontWeight="SemiBold" Foreground="#E6E1E5"/>
                                            <TextBlock Text="Scan for devices on your network" FontSize="12" Foreground="#CAC4D0" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🔍 Scan" Command="{Binding ScanDevicesCommand}"
                                                Classes="Tonal" Padding="20,10"
                                                IsEnabled="{Binding !IsScanning}"/>
                                    </Grid>
                                </Border>

                                <Border Classes="Elevated" MinHeight="80" MaxHeight="120" IsVisible="{Binding DiscoveredDevices.Count}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <ListBox ItemsSource="{Binding DiscoveredDevices}" SelectedItem="{Binding SelectedDevice}"
                                                 Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="📱" FontSize="16" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" VerticalAlignment="Center" Foreground="#E6E1E5"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <Button Grid.Column="1" Content="Select" Command="{Binding SelectDeviceCommand}" 
                                                CommandParameter="{Binding SelectedDevice}"
                                                Classes="Tonal" Padding="16,8" Margin="12,0,0,0"
                                                IsEnabled="{Binding SelectedDevice, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Files Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border Background="#4A4458" CornerRadius="12" Padding="10">
                                            <TextBlock Text="📁" FontSize="20"/>
                                        </Border>
                                        <TextBlock Text="Files to Send" FontSize="20" FontWeight="SemiBold" Foreground="#E6E1E5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                        <Button Content="📂 Select Files" Command="{Binding SelectFilesCommand}" CommandParameter="{Binding $parent[Window]}"/>
                                        <Button Content="🗑️ Clear" Command="{Binding ClearFilesCommand}" 
                                                Classes="Outlined" Padding="16,10"/>
                                    </StackPanel>
                                </Grid>

                                <Border Background="#36343B" CornerRadius="12" Padding="16" MinHeight="100" MaxHeight="150">
                                    <ListBox ItemsSource="{Binding SelectedFiles}" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="📄" FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding}" FontSize="13" TextTrimming="CharacterEllipsis" 
                                                               Foreground="#E6E1E5" MaxWidth="450"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Action Button -->
                        <Button Content="📤 SEND FILES" Command="{Binding SendFilesCommand}" CommandParameter="{Binding $parent[Window]}"
                                Classes="FilledSuccess" HorizontalAlignment="Stretch"
                                IsEnabled="{Binding !IsSending}"/>

                        <!-- Progress Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Status}" FontSize="14" Foreground="#CAC4D0" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentFileProgress}" FontSize="14" 
                                               Foreground="#D0BCFF" FontWeight="SemiBold"/>
                                </Grid>
                                <TextBlock Text="{Binding CurrentFileName}" FontSize="13" Foreground="#938F99" 
                                           TextTrimming="CharacterEllipsis" FontStyle="Italic"
                                           IsVisible="{Binding CurrentFileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsSending}">
                                    <Border Background="#166534" CornerRadius="8" Padding="8,4">
                                        <TextBlock Text="Sending..." Foreground="#86EFAC" FontWeight="Medium" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- RECEIVE TAB -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📥" FontSize="18"/>
                        <TextBlock Text="Receive" VerticalAlignment="Center" Foreground="#E6E1E5"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer Padding="0,24,0,0">
                    <StackPanel Spacing="16">
                        
                        <!-- Connection Info Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="#4A4458" CornerRadius="12" Padding="10">
                                        <TextBlock Text="🌐" FontSize="20"/>
                                    </Border>
                                    <TextBlock Text="Connection Info" FontSize="20" FontWeight="SemiBold" Foreground="#E6E1E5" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Your IP" VerticalAlignment="Center" 
                                               Foreground="#CAC4D0" FontWeight="Medium" Margin="0,0,24,0"/>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#4A4458" CornerRadius="8" Padding="16,12" HorizontalAlignment="Left" MinWidth="180">
                                        <TextBlock Text="{Binding LocalIp}" FontWeight="SemiBold" Foreground="#B8F0C2" FontSize="15"/>
                                    </Border>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" VerticalAlignment="Center" 
                                               Foreground="#CAC4D0" FontWeight="Medium" Margin="0,16,24,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port}" Width="100" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                                </Grid>

                                <Border Background="#4A4458" CornerRadius="12" Padding="16">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="👆" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Share this IP and port with the sender" Foreground="#CAC4D0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Download Folder Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="#4A4458" CornerRadius="12" Padding="10">
                                        <TextBlock Text="📂" FontSize="20"/>
                                    </Border>
                                    <TextBlock Text="Save Location" FontSize="20" FontWeight="SemiBold" Foreground="#E6E1E5" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Border Classes="Elevated">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel>
                                            <TextBlock Text="Download folder" FontWeight="Medium" Foreground="#E6E1E5"/>
                                            <TextBlock Text="{Binding DownloadFolder, FallbackValue='Default: ~/Downloads'}" 
                                                       FontSize="12" Foreground="#CAC4D0" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Choose" Command="{Binding SelectDownloadFolderCommand}" 
                                                CommandParameter="{Binding $parent[Window]}"
                                                Classes="Tonal" Padding="16,8"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                            <Button Grid.Column="0" Content="📥 START RECEIVING" Command="{Binding ToggleReceivingCommand}" CommandParameter="{Binding $parent[Window]}"
                                    Classes="FilledSecondary" HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="⏹️ STOP" Command="{Binding StopReceivingCommand}"
                                    Classes="FilledTertiary" HorizontalAlignment="Stretch" Margin="8,0,0,0"
                                    IsEnabled="{Binding IsReceiving}"/>
                        </Grid>

                        <!-- Progress Card -->
                        <Border Classes="Card">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding Status}" FontSize="14" Foreground="#CAC4D0" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CurrentFileProgress}" FontSize="14" 
                                               Foreground="#CCC2DC" FontWeight="SemiBold"/>
                                </Grid>
                                <TextBlock Text="{Binding CurrentFileName}" FontSize="13" Foreground="#938F99" 
                                           TextTrimming="CharacterEllipsis" FontStyle="Italic"
                                           IsVisible="{Binding CurrentFileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsReceiving}">
                                    <Border Background="#7D2E3F" CornerRadius="8" Padding="8,4">
                                        <TextBlock Text="Receiving..." Foreground="#F4C7D5" FontWeight="Medium" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
        </TabControl>
    </DockPanel>

</Window>
