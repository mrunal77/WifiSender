<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WifiSender.App"
             xmlns:local="using:WifiSender"
               RequestedThemeVariant="Default">
             <!-- "Default" follows system theme. "Dark" or "Light" force a specific variant. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>